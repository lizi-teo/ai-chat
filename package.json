{
  "name": "@lizi-teo/ai-chat-ui",
  "version": "0.2.0",
  "description": "White-label AI chat component library for retail, pharmacy, grocery, travel and insurance chatbots",
  "author": "Lizzie Teo",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./primitives": {
      "import": "./dist/primitives.js",
      "types": "./dist/components/primitives/index.d.ts"
    },
    "./styles": "./app/globals.css",
    "./theme": "./app/theme.css"
  },
  "files": [
    "dist",
    "app/globals.css",
    "app/theme.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lizi-teo/ai-chat.git"
  },
  "scripts": {
    "dev": "vite",
    "next": "next dev",
    "build": "vite build --config vite.lib.config.ts && tsc -p tsconfig.build.json",
    "build:next": "next build",
    "start": "next start",
    "lint": "eslint",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-themes": "^10.4.2",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/nextjs-vite": "^10.4.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "chromatic": "^17.3.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "eslint-plugin-storybook": "^10.4.2",
    "playwright": "^1.60.0",
    "storybook": "^10.4.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
